# Deporty - Variables de entorno para Vercel

# Base de datos PostgreSQL - IMPORTANTE para Alto Rendimiento
# SIEMPRE usa la URL con Connection Pooler (-pooler) para Vercel Serverless
# Ejemplo Vercel Postgres: postgres://user:pass@db-pooler.postgres.vercel-storage.com/db
# Ejemplo Neon: postgres://user:pass@host.neon.tech/db?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:password@host-pooler:5432/database?sslmode=require&connection_limit=1"

# URL directa (sin pooler) - SOLO para migraciones de Prisma
# Descomenta si usas Vercel Postgres o Neon (migraciones requieren conexión directa)
# DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT (para autenticación)
JWT_SECRET="tu_secret_key_super_seguro_aqui"

# CORS
CORS_ORIGIN="https://deporty.com"

# Entorno
NODE_ENV="production"
