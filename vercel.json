{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": "vanilla",
  "public": "public",
  
  "env": [
    "CORS_ORIGIN",
    "DATABASE_URL",
    "JWT_SECRET",
    "NODE_ENV"
  ],

  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 10,
      "runtime": "nodejs18.x"
    }
  },

  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ],

  "redirects": [
    {
      "source": "/index",
      "destination": "/"
    }
  ],

  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/public/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|woff|woff2|eot|ttf|otf|svg|png|jpg|jpeg|gif|webp))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.*",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
